generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  DEPARTMENT_OFFICER
  ADMIN
  SUPER_ADMIN
}

enum ReportStatus {
  SUBMITTED
  VERIFIED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
  REOPENED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueCategory {
  ROAD_DAMAGE
  GARBAGE_OVERFLOW
  STREET_LIGHT
  WATER_LEAKAGE
  DRAINAGE
  PUBLIC_SAFETY
  OTHER
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      UserRole @default(CITIZEN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports         Report[]   @relation("CitizenReports")
  assignedReports Report[]   @relation("OfficerReports")
  auditLogs       AuditLog[]
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reports Report[]
}

model Report {
  id          String         @id @default(cuid())
  title       String
  description String
  category    IssueCategory
  status      ReportStatus   @default(SUBMITTED)
  priority    ReportPriority @default(LOW)

  latitude  Float
  longitude Float
  address   String?

  citizenId    String
  departmentId String?
  officerId    String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  citizen    User        @relation("CitizenReports", fields: [citizenId], references: [id])
  officer    User?       @relation("OfficerReports", fields: [officerId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  images        ReportImage[]
  statusHistory ReportStatusHistory[]
  auditLogs     AuditLog[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([departmentId])
  @@index([officerId])
  @@index([latitude, longitude])
}

model ReportImage {
  id        String   @id @default(cuid())
  reportId  String
  imageUrl  String
  publicId  String?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportStatusHistory {
  id        String        @id @default(cuid())
  reportId  String
  oldStatus ReportStatus?
  newStatus ReportStatus
  note      String?
  createdAt DateTime      @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   Json?
  userId    String?
  reportId  String?
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  report Report? @relation(fields: [reportId], references: [id])
}
